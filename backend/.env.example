# Database
DATABASE_URL=postgresql://postgres:my-postgre-passwor@localhost:5432/reqTool
TEST_DATABASE_URL=postgresql://postgres:my-postgre-password@localhost:5432/reqTool_test

# JWT
SECRET_KEY=random key generated from the terminal
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Qdrant Vector Database
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=mu-quadrant-API-key

# AI Providers (at least one required)
ANTHROPIC_API_KEY=generated API-key from my claude account


# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=myemail-email@gmail.com (for local host -testing (before Brevo service))
BREVO_API_KEY=API generated from my brevo account (for production - email service)   

# App
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
KNOWLEDGE_BASE_PATH=Knowledge_base
