@startuml Session & Requirement Pipeline



[*] --> SelectingDomain : User authenticated

state "Step 1-3: Role & Questionnaire" as Setup {
    [*] --> SelectingCountry
    SelectingCountry --> SelectingDomain : Country and domain chosen
    SelectingDomain --> SelectingRole  : Role Chosen
    SelectingRole --> FillingQuestionnaire : Answering Questions
    FillingQuestionnaire --> ReadyToSubmit : Role & answers complete
}

Setup --> SessionCreated : POST /domains/session [201 Created]

state "Step 4: Document Input" as Input {
    [*] --> AwaitingInput
    AwaitingInput --> ProcessingText      : Text pasted / typed
    AwaitingInput --> ProcessingDocument  : File uploaded (PDF / DOCX)
    ProcessingDocument --> AwaitingInput  : Invalid file [400 / 413] -- retry
    ProcessingText     --> InputReady     : PII scan complete
    ProcessingDocument --> InputReady     : PII scan complete
    InputReady : entry / Show PII warning if pii_detected=true
}

SessionCreated --> Input

Input --> GeneratingRequirements : POST /requirements/generate\n[document_text + session_id]

state GeneratingRequirements {
    [*] --> CallingAI
    CallingAI --> ParsingResponse : AI returns FR & NFR list
    CallingAI --> AIError         : AI returns error
    ParsingResponse --> SavingToDB : Delete old requirements\nthen INSERT new FR & NFR
    AIError --> [*]
}

GeneratingRequirements --> Input                 : AI error -- retry with same or new document
GeneratingRequirements --> ReviewingRequirements : FR & NFR saved to DB

state "Step 5: Requirements Refinement" as ReviewingRequirements {

    state Requirement {
        [*]         --> AIGenerated : Created by AI\n(is_edited=false)
        AIGenerated --> Edited      : PUT /requirements/{id}\nold_description saved to RequirementHistory\nis_edited=true
        Edited      --> Edited      : Further edits\n(new RequirementHistory entry each time)
    }
}

ReviewingRequirements --> GeneratingRequirements : Regenerate all\n(old requirements deleted first)

state "Document Generation" as DocGen {
    [*] --> GeneratingSRS
    [*] --> GeneratingUseCases
    GeneratingSRS      --> SRSReady
    GeneratingUseCases --> UseCasesReady
}

ReviewingRequirements --> DocGen : Generate SRS / Use Cases
DocGen --> [*] : Downloaded as DOCX

@enduml
