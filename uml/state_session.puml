@startuml State Machine - User Session

title User Session (Wizard Run) Lifecycle

skinparam stateBorderColor #1E2A4A
skinparam stateBackgroundColor #F8F9FA
skinparam stateFontColor #1E2A4A
skinparam ArrowColor #FF6B6B
skinparam noteBackgroundColor #FFF5F5
skinparam noteBorderColor #FF6B6B

[*] --> WizardInProgress : User starts wizard\n(frontend only, no DB yet)

state WizardInProgress {
  state "Step 1: Domain" as S1
  state "Step 2: Role" as S2
  state "Step 3: Questions" as S3
  state "Step 4: Input" as S4
  state "Step 5: Review" as S5

  S1 --> S2 : Select domain
  S2 --> S3 : Select role
  S3 --> S4 : Answer all questions
  S4 --> S5 : Process input text/file
}

WizardInProgress --> Created : Click "Generate Requirements"\nPOST /domains/session\n(session saved to DB)

state Created {
  Created : stored in user_sessions table
  Created : has domain, role, answers
  Created : no requirements yet
}

Created --> RequirementsGenerated : POST /requirements/generate\n(AI generates requirements)

state RequirementsGenerated {
  RequirementsGenerated : requirements saved to DB
  RequirementsGenerated : functional + non-functional
  RequirementsGenerated : user can edit/add/delete
}

RequirementsGenerated --> SRSGenerated : POST /srs/generate\n(Claude generates SRS doc)
RequirementsGenerated --> UseCasesGenerated : POST /use-cases/generate\n(Claude generates use cases)
RequirementsGenerated --> CrossChecked : POST /crosscheck\n(Claude validates requirements)

state SRSGenerated {
  SRSGenerated : SRS document ready
  SRSGenerated : can be downloaded
}

state UseCasesGenerated {
  UseCasesGenerated : use cases list ready
  UseCasesGenerated : can be downloaded
}

state CrossChecked {
  CrossChecked : issues list returned
  CrossChecked : user reviews findings
}

SRSGenerated --> RequirementsGenerated : User edits requirements\nand regenerates
UseCasesGenerated --> RequirementsGenerated : User edits requirements\nand regenerates
CrossChecked --> RequirementsGenerated : User fixes issues\nand re-checks

note right of Created
  session_id passed in URL
  as query parameter
  and stored in localStorage
end note

note right of RequirementsGenerated
  Requirements persist in DB
  User can return to this
  session anytime via profile
end note

@enduml
