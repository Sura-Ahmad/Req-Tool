@startuml Sequence Diagram - Password Reset Flow

title Password Reset Flow

skinparam sequenceArrowThickness 2
skinparam sequenceParticipantBorderColor #1E2A4A
skinparam sequenceParticipantBackgroundColor #F8F9FA
skinparam sequenceLifeLineBorderColor #1E2A4A
skinparam sequenceArrowColor #FF6B6B
skinparam noteBorderColor #FF6B6B
skinparam noteBackgroundColor #FFF5F5

actor User
participant "Frontend\n(Next.js)" as FE
participant "AuthRouter" as AR
participant "AuthService" as AS
participant "SecurityCore" as SC
participant "EmailCore\n(Brevo)" as EM
participant "Brevo\nAPI" as BR
database "PostgreSQL" as DB

== Request Reset ==

User -> FE: Enter email on\nForgot Password page
FE -> AR: POST /auth/forgot-password\n{ email }

AR -> DB: SELECT User WHERE email=?
DB --> AR: User found (or not)

note over AR
  Always returns same response
  to prevent email enumeration
end note

alt User exists and is active
  AR -> DB: UPDATE existing tokens\nSET is_used=true
  AR -> AR: Generate random token\n(secrets.token_urlsafe)
  AR -> SC: hash_token(token)
  SC --> AR: token_hash
  AR -> DB: INSERT PasswordResetToken\n(user_id, hash, expires_at=+1hr)
  AR -> EM: send_reset_email()\n[BackgroundTask]
  EM -> BR: POST /v3/smtp/email\n{ to, subject, html_link }
  BR --> EM: 200 OK
  EM -> EM: log "email sent"
end

AR --> FE: { message: "If registered,\nyou will receive a link" }
FE --> User: Show confirmation message

== Reset Password ==

User -> User: Open email,\nclick Reset button
User -> FE: Visit /auth/reset-password\n?token=<raw_token>
FE --> User: Show new password form

User -> FE: Enter new password
FE -> AR: POST /auth/reset-password\n{ token, new_password }

AR -> AS: validate_password_strength(password)
AS --> AR: valid ✓

AR -> SC: hash_token(token)
SC --> AR: token_hash
AR -> DB: SELECT PasswordResetToken\nWHERE hash=?\nAND is_used=false\nAND expires_at > now()
DB --> AR: Token record

alt Token valid
  AR -> DB: SELECT User WHERE id=?
  AR -> SC: hash_password(new_password)
  SC --> AR: new_hash
  AR -> DB: UPDATE User SET password_hash=?
  AR -> DB: UPDATE Token SET is_used=true
  AR --> FE: { message: "Password reset successfully" }
  FE --> User: Redirect to login page
else Token invalid or expired
  AR --> FE: 400 "Invalid or expired reset link"
  FE --> User: Show error message
end

@enduml
